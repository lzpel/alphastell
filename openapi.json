{
  "openapi": "3.1.0",
  "info": {
    "title": "alphastell API",
    "version": "0.1.0",
    "description": "HTTP facade over the alphastell vessel/magnet subcommands. Upload a VMEC NetCDF or MAKEGRID coils file and receive the generated STEP + CSV artifacts as a list of base64-encoded files."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/vessel": {
      "post": {
        "operationId": "uploadVmec",
        "summary": "Generate in-vessel components from a VMEC NetCDF file",
        "description": "Equivalent to the `vessel` subcommand. Accepts a VMEC `wout_*.nc` file and returns 12 artifacts: 6 STEP solids (chamber, first_wall, breeder, back_wall, shield, vacuum_vessel) and their corresponding CSV point clouds.",
        "parameters": [
          {
            "name": "wall_s",
            "in": "query",
            "required": false,
            "description": "Reference flux surface. Parastell default 1.08 (just outside the LCFS).",
            "schema": {
              "type": "number",
              "format": "double",
              "default": 1.08
            }
          },
          {
            "name": "scale",
            "in": "query",
            "required": false,
            "description": "Unit scaling factor. VMEC is in meters; 100 converts to centimeters to match the parastell default.",
            "schema": {
              "type": "number",
              "format": "double",
              "default": 100.0
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": ["file"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "VMEC NetCDF-3 64-bit offset file (wout_*.nc)."
                  }
                }
              },
              "encoding": {
                "file": {
                  "contentType": "application/octet-stream"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated in-vessel artifacts (6 STEP + 6 CSV).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileList"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input file or parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Processing failure.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/magnet": {
      "post": {
        "operationId": "uploadCoils",
        "summary": "Generate a magnet_set STEP from a MAKEGRID coils file",
        "description": "Equivalent to the `magnet` subcommand. Accepts a MAKEGRID-format coils file (e.g. `coils.example`) and returns 2 artifacts: a STEP of the swept rectangular-section coils and its CSV point cloud.",
        "parameters": [
          {
            "name": "width",
            "in": "query",
            "required": false,
            "description": "Rectangular cross-section width [m]. Default 0.4 m matches parastell.",
            "schema": {
              "type": "number",
              "format": "double",
              "default": 0.4
            }
          },
          {
            "name": "thickness",
            "in": "query",
            "required": false,
            "description": "Rectangular cross-section thickness [m]. Default 0.5 m matches parastell.",
            "schema": {
              "type": "number",
              "format": "double",
              "default": 0.5
            }
          },
          {
            "name": "toroidal_extent",
            "in": "query",
            "required": false,
            "description": "Toroidal extent [deg]. 360 keeps all coils; values below 360 are reserved for future use.",
            "schema": {
              "type": "number",
              "format": "double",
              "default": 360.0
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": ["file"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "MAKEGRID-format coils file (text)."
                  }
                }
              },
              "encoding": {
                "file": {
                  "contentType": "application/octet-stream"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated magnet artifacts (1 STEP + 1 CSV).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileList"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input file or parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Processing failure.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FileEntry": {
        "type": "object",
        "additionalProperties": false,
        "required": ["filename", "content_type", "data"],
        "properties": {
          "filename": {
            "type": "string",
            "description": "Output filename, e.g. `chamber.step` or `magnet_set.csv`."
          },
          "content_type": {
            "type": "string",
            "description": "MIME type hint for the payload (e.g. `model/step`, `text/csv`)."
          },
          "data": {
            "type": "string",
            "format": "byte",
            "description": "Base64-encoded file contents."
          }
        }
      },
      "FileList": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/FileEntry"
        }
      },
      "Error": {
        "type": "object",
        "additionalProperties": false,
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
